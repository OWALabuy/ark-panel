# 只含非敏感配置示例；不要把密码哈希、会话密钥或 gateway token 提交到仓库。
PANEL_DATA_DIR=/home/USER/.local/share/ark-panel
PANEL_CONTEXT_HISTORY_BUDGET_TOKENS=100000
PANEL_READ_AGENTS={"claude":{"sessionsRoot":"/home/USER/.openclaw/agents/claude/sessions","label":"Claude"},"main":{"sessionsRoot":"/home/USER/.openclaw/agents/main/sessions","label":"Main"}}
PANEL_AGENT_RUNTIMES={"claude":{"runtimeAgentId":"panel-claude-runtime","sessionsRoot":"/home/USER/.openclaw/agents/panel-claude-runtime/sessions"},"main":{"runtimeAgentId":"panel-main-runtime","sessionsRoot":"/home/USER/.openclaw/agents/panel-main-runtime/sessions"}}

# 以下值必须在部署环境中另行设置，此处故意不提供示例秘密：
# PANEL_USERNAME=
# PANEL_PASSWORD_HASH=
# PANEL_SESSION_SECRET=
